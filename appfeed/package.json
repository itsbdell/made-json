{
  "name": "@made-json/cli",
  "version": "0.1.0",
  "description": "Reference CLI for the made.json standard. Validate and maintain made.json feeds. Installs the 'appfeed' binary.",
  "homepage": "https://made-json.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/itsbdell/made-json.git",
    "directory": "appfeed"
  },
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "appfeed": "bin/appfeed.js"
  },
  "files": [
    "bin/",
    "src/",
    "README.md"
  ],
  "scripts": {
    "sync-schemas": "node ../scripts/sync-schemas.js",
    "prepublishOnly": "npm run sync-schemas",
    "test": "node --test test/"
  },
  "keywords": [
    "made.json",
    "feed",
    "validator",
    "vibe-coded",
    "cli"
  ],
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1"
  }
}
